# === Telegram ===
# Токен бота от @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# === OpenRouter (AI) ===
# Ключ от openrouter.ai, начинается с sk-or-
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Модели (задаём строкой — меняются без правки кода)
# Для разработки ставим бесплатную, в проде подберём оптимальную
MODEL_DIALOG=deepseek/deepseek-chat
MODEL_ANALYSIS=deepseek/deepseek-chat

# === Контроль расходов ===
# Дневной потолок расходов на AI в долларах (наша защита из архитектуры)
DAILY_COST_LIMIT_USD=1.0

# === Прочее ===
# Твой Telegram ID — сюда бот будет слать обратную связь, алерты и /stats
ADMIN_USER_ID=your_telegram_id_here

# Опционально: HTTP/SOCKS5 прокси (если OpenRouter недоступен напрямую)
# PROXY_URL=socks5://127.0.0.1:7890

# Путь к SQLite (по умолчанию bot_database.db в корне проекта)
# DB_PATH=./bot_database.db

# === Лимиты бесплатного тарифа ===
FREE_LIMIT_MESSAGES=15
FREE_LIMIT_WORDS_SESSIONS=1
FREE_LIMIT_GRAMMAR_EXERCISES=1

# === Платежи ===
# manual — для dev (admin активирует через /grant_premium)
# yookassa — боевые платежи + webhook
PAYMENT_PROVIDER=manual
PREMIUM_PRICE_MONTH=299
PREMIUM_PRICE_YEAR=2490
PREMIUM_DAYS_MONTH=30
PREMIUM_DAYS_YEAR=365
PAYMENT_RETURN_URL=https://t.me/your_bot_username

# ЮKassa (если PAYMENT_PROVIDER=yookassa)
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=
# WEBHOOK_PORT=8080